# RTG / RTFoundation — omgevingsvariabelen
# Kopieer naar .env (of zet ze in je hosting) en vul in. .env staat in .gitignore.
# In productie weigert de server te starten bij een onveilige combinatie
# (zie server/config.js): dat is bewust.

# --- kern ---
NODE_ENV=production              # 'production' zet demo uit en https/HSTS aan
PORT=3000
# Draden voor zwaar rekenwerk naast de server (scrypt bij inloggen).
# server.js zet standaard evenveel draden als CPU-kernen (minimaal 4);
# alleen zetten als je bewust wilt afwijken. Meer dan het aantal kernen
# levert niets op: scrypt is puur rekenwerk.
# UV_THREADPOOL_SIZE=8
# De archiefkast: afgeronde tickets ouder dan dit aantal dagen verhuizen naar
# append-only maandbestanden (RTG_DATA_DIR/archief). Standaard 92: een
# afgesloten kwartaal plus marge, zodat maandcijfers altijd over levende
# data rekenen. De export en backoffice-totalen tellen het archief mee.
# RTG_ARCHIEF_DAGEN=92
APP_URL=https://app.rtg.example  # basis-URL voor links in e-mails

# --- de eigenaar (VERPLICHT in productie) ---
# Het account met dit e-mailadres is eigenaar van de technische pagina
# (zekeringen, functieschakelaars, beveiligingsmeldingen). Met het voorbeeld-
# adres of leeg weigert de server te starten: anders zou iedereen die dat
# adres registreert eigenaar worden.
RTG_OWNER_EMAIL=

# Tip: `npm run sleutels` genereert alle geheimen hieronder in een keer;
# `npm run golive` keurt daarna de complete omgeving voordat je live gaat.

# --- versleuteling-at-rest (sterk aanbevolen in productie) ---
# 64 hex-tekens of 32+ willekeurige tekens. Genereer met:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RTG_ENC_KEY=
# Zet op 1 om bewust ZONDER versleuteling te draaien (afgeraden):
# RTG_ALLOW_PLAINTEXT=1

# --- accountsleutels (identiteitskluis + sessietokens) ---
# BIJ MEERDERE INSTANCES verplicht en op elke instance GELIJK: anders kan de ene
# instance de versleutelde naam/e-mail van de andere niet lezen en klopt de
# e-mail-login-hash niet. 64 hex-tekens elk (crypto.randomBytes(32).toString('hex')).
RTG_VAULT_KEY=                   # versleutelt naam/e-mail + e-mail/telefoon-hash
RTG_SECRET_KEY=                  # ondertekent sessietokens
# RTG_MAX_SESSIONS=50000         # max. gelijktijdige sessies (verlopen gaan eerst weg)

# --- observability ---
LOG_LEVEL=info                   # debug|info|warn|error
# LOG_JSON=1                     # forceer JSON-logs ook buiten productie
SENTRY_DSN=                      # optioneel; leeg = geen externe fout-tracking
# SENTRY_TRACES=0.1              # aandeel traces (0..1)
RTG_SERVICE=rtg                  # naam in de logregels

# --- opslag ---
# Gezet -> de gedeelde data draait op PostgreSQL (aanbevolen voor productie en
# voor meerdere app-instances). Leeg -> lokaal bestand (json), of RTG_STORE=sqlite.
DATABASE_URL=                    # bijv. postgresql://user:pass@host:5432/rtg
# RTG_STORE=postgres|sqlite|json # normaal automatisch: postgres als DATABASE_URL gezet is
# Waar de lokale data, backups, outbox en het archief landen. Standaard
# server/data. Zet dit op een persistente schijf (niet de container-laag).
# RTG_DATA_DIR=/var/lib/rtg

# --- kantoor (RTG Office / bemiddelaar) ---
# Toegangscode voor de kantoorschermen. Leeg in productie -> de server kiest een
# onraadbare willekeurige code (dan is het kantoor dus niet bereikbaar tot je er
# zelf een zet). Minstens 8 tekens.
# OFFICE_CODE=
# Tweede factor (TOTP) op de backoffice, zoals bij de bank: zet hier een
# base32-geheim en voer hetzelfde geheim in een authenticator-app in
# (Google/Microsoft Authenticator, 1Password). Leeg = 2FA uit (demo).
# OFFICE_TOTP_SECRET=
# Rate-limiter op de API (300 verzoeken per minuut per IP). Staat in
# productie automatisch aan; met RTG_RATELIMIT=1 ook daarbuiten.
# RTG_RATELIMIT=

# --- schild (applicatie-WAF + DDoS-rem, altijd aan) ---
# Plafond per IP per 10 seconden voordat het IP 15 minuten op de banlijst
# gaat. WAF-treffers (pad-klimmen, scanner-sondes) tellen extra zwaar.
# Localhost is uitgezonderd. Volumetrische netwerk-DDoS hoort daarnaast bij
# de rand (Cloudflare/vergelijkbaar), zie PRODUCTION.md.
# RTG_SCHILD_PLAFOND=400

# --- (video)bellen: STUN/TURN ---
# Zonder TURN werkt bellen alleen als beide toestellen elkaar direct kunnen
# bereiken; met TURN werkt het ook door strenge firewalls en 4G-NAT heen.
# Voorkeur: een eigen coturn met use-auth-secret; de server maakt dan per
# aanvraag kortlevende inloggegevens (1 uur, HMAC) in plaats van een vast
# wachtwoord. TURN_USER/TURN_PASS blijft werken als statische terugval.
# STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:turn.rtg.example:3478,turns:turn.rtg.example:5349
# TURN_SECRET=                    # zelfde waarde als static-auth-secret in coturn
# TURN_USER=
# TURN_PASS=

# --- realtime over meerdere instances ---
REDIS_URL=                       # bijv. redis://localhost:6379 ; leeg = één proces

# --- persoonlijke AI / vertaling ---
ANTHROPIC_API_KEY=               # leeg = demo-antwoorden

# --- e-mail (herstel-links, bevestigingen) ---
# SMTP_URL=smtps://user:pass@smtp.example:465
# of los:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="RTG <no-reply@rtg.example>"

# --- betalingen (Stripe) ---
STRIPE_SECRET_KEY=               # leeg = demo-betalingen (geen echt geld)
STRIPE_WEBHOOK_SECRET=           # nodig om Stripe-webhooks te verifiëren

# --- RTFoundation-afdracht (30% van elke maandbetaling) ---
# Van elke bevestigde maandbetaling gaat automatisch 30% (ex btw) naar de
# foundation. Zonder IBAN wordt de afdracht per betaling geboekt en gereserveerd
# (status "te_storten"); zodra het IBAN hier staat, wordt hij als uitbetaling
# ingepland. Vul dit in zodra het rekeningnummer bekend is.
RTF_IBAN=                        # bijv. NL00 BANK 0123 4567 89 (foundation-rekening)
RTF_BEGUNSTIGDE=Stichting RTFoundation
RTF_BANK=                        # optioneel: naam van de bank/BIC

# --- cryptomunten ontvangen (via een vergunninghoudende aanbieder) ---
# RTG accepteert munten voor zijn EIGEN diensten en zet ze meteen om naar euro's;
# we bewaren zelf geen crypto en bieden geen wisseldienst aan derden (geen CASP).
# Acceptatie staat standaard UIT. Laat compliance/DNB (MiCA, Wwft/KYC, fiscaal)
# dit bevestigen voordat u het live zet.
MUNT_AAN=                        # 1 = acceptatie aan (alleen samen met een provider)
MUNT_PROVIDER_KEY=               # sleutel van de vergunninghoudende munt-aanbieder; leeg = demo
MUNT_WEBHOOK_SECRET=             # verifieert de munt-webhook (ontvangen + omgezet)
MUNT_MUNTEN=btc,eth,usdc         # welke munten geaccepteerd worden

# --- mediastore: Salon-foto's en snaps (schijf of S3) ---
# Foto's staan als losse (versleutelde) bestanden buiten de database, met alleen
# een verwijzing in de data. Standaard 'disk' (DATA_DIR/media). Voor meerdere
# instances / miljoenen gebruikers: zet 's3' zodat alle servers dezelfde,
# S3-compatibele opslag delen (AWS S3, Cloudflare R2, MinIO, Backblaze B2).
RTG_MEDIA_BACKEND=               # leeg/disk = lokale schijf; s3 = objectopslag
RTG_MEDIA_S3_BUCKET=             # bucketnaam
RTG_MEDIA_S3_REGION=us-east-1    # regio (voor AWS)
RTG_MEDIA_S3_ENDPOINT=           # leeg = AWS; anders bijv. https://<account>.r2.cloudflarestorage.com of http://minio:9000
RTG_MEDIA_S3_KEY=                # access key id (of AWS_ACCESS_KEY_ID)
RTG_MEDIA_S3_SECRET=             # secret access key (of AWS_SECRET_ACCESS_KEY)
RTG_MEDIA_S3_PREFIX=media/       # sleutel-voorvoegsel in de bucket

# --- failover-cluster (alleen bij server/trio.js) ---
RTG_CLUSTER_KEY=                 # gedeeld geheim tussen de drie servers

# --- back-ups ---
# RTG_BACKUP_DIR=/mnt/backup/rtg # extra kopie naar een tweede schijf/mount

# --- NIET in productie zetten ---
# RTG_DEMO=1                     # zou de demo-inlog openzetten; server weigert dit in productie
# DEMO_PASS=...                  # standaard 'Imran'; in productie verboden
