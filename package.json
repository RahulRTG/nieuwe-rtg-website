{
  "name": "rtg-website",
  "version": "1.0.0",
  "private": true,
  "description": "Rahul Travel Group, website, ledenportaal en backend",
  "scripts": {
    "start": "node server/trio.js",
    "single": "node --experimental-sqlite server/server.js",
    "gateway": "node server/poort.js",
    "vloot": "node server/vloot.js",
    "sleutels": "node scripts/sleutels.js",
    "golive": "node scripts/golive.js",
    "spitsuur": "node scripts/spitsuur.js",
    "nood": "node server/nood.js",
    "check": "node scripts/check.js",
    "a11y": "node scripts/a11y.js",
    "build": "node scripts/build.js",
    "test": "node --experimental-sqlite --test test/*.test.js",
    "test:coverage": "node --experimental-sqlite --experimental-test-coverage --test test/*.test.js",
    "audit": "npm audit --audit-level=high",
    "e2e": "node --experimental-sqlite --test test/*.e2e.js",
    "chaos": "node --experimental-sqlite scripts/chaos-soak.js",
    "icons": "node scripts/icons.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.21.0",
    "nodemailer": "^9.0.3",
    "web-push": "^3.6.7"
  },
  "optionalDependencies": {
    "@sentry/node": "^10.66.0",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "axe-core": "^4.12.1",
    "terser": "^5.49.0"
  }
}
